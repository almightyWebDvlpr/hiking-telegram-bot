APP_STAGE=prod
BOT_TOKEN_PROD=your_prod_telegram_bot_token
BOT_USERNAME_PROD=your_prod_bot_username
BOT_TOKEN_TEST=your_test_telegram_bot_token
BOT_USERNAME_TEST=your_test_bot_username
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hiking_db
MONGODB_DB=hiking_db
MONGODB_COLLECTION_PROD=app_state_prod
MONGODB_COLLECTION_TEST=app_state_test
MIGRATION_FILE=./data/store.json
OPENROUTESERVICE_API_KEY=your_openrouteservice_key
GRAPHHOPPER_API_KEY=your_graphhopper_key
VPOHID_ARCHIVE_SYNC_ENABLED=true
VPOHID_ARCHIVE_SYNC_HOURS=24
VPOHID_ARCHIVE_SYNC_STARTUP_DELAY_MINUTES=3
